APP_NAME=Automotive Insurance Claim Workflow Orchestration System
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX=/api/v1
DOCUMENT_STORAGE_PATH=storage/documents
MAX_DOCUMENT_SIZE_BYTES=10485760
DATABASE_URL=postgresql+psycopg://claims_user:claims_password@postgres:5432/claims_db
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
POSTGRES_DB=claims_db
POSTGRES_USER=claims_user
POSTGRES_PASSWORD=claims_password
